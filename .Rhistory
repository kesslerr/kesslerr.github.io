library(candela)
data <- list(
list(name='Education', level=1, start=2010, end=2023),
list(name='Biology BSc', level=2, start=2010, end=2014),
list(name='Cognitive Neurosciences MSc', level=2, start=2014, end=2016),
list(name='Cognitive Neurosciences PhD', level=2, start=2016, end=2022),
list(name='Data Science MSc', level=2, start=2019, end=2022),
list(name='Experience', level=1, start=2010, end=2023),
list(name='Cognitive Neuroscientist', level=2, start=2016, end=2021),
list(name='Data Analyst / Data Scientist', level=2, start=2022, end=2023))
candela('GanttChart',
data=data, label='name',
start='start', end='end', level='level',
width=1500, height=500)
?candela
